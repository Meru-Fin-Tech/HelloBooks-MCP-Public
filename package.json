{
  "name": "hellobooks-mcp-public",
  "version": "1.5.0",
  "description": "Public read-only MCP server exposing HelloBooks plans, integrations, country support, compliance capabilities, competitor positioning, statutory compliance deadlines, local payment methods, feature catalog data, published articles, and product videos to AI agents. Self-describing discovery surface (HTML landing, /.well-known/agent.json, /llms.txt, /catalog.json, /sitemap.xml, RSS, OpenAPI) at the origin so AI crawlers can index the server.",
  "license": "MIT",
  "author": "HelloBooks <hello@hellobooks.ai>",
  "homepage": "https://hellobooks.ai/mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/Meru-Fin-Tech/HelloBooks-MCP-Public.git"
  },
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "hellobooks-mcp-public": "dist/stdio.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/http.js",
    "start:stdio": "node dist/stdio.js",
    "dev": "tsx watch src/http.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "test": "node --test --import tsx test/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test --import tsx test/*.test.ts",
    "lint": "tsc --noEmit",
    "audit:public-data": "node --import tsx scripts/audit-public-data.ts",
    "check:deadline-drift": "node --import tsx scripts/check-deadline-drift.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.18.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "c8": "^10.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hellobooks",
    "accounting",
    "ai-agent",
    "anthropic",
    "claude"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ]
}
