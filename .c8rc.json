{
  "all": true,
  "src": ["src"],
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/data/**",
    "src/**/*.d.ts",
    "src/stdio.ts",
    "src/http.ts"
  ],
  "extension": [".ts"],
  "reporter": ["text", "lcov"],
  "report-dir": "coverage",
  "lines": 70,
  "functions": 70,
  "branches": 60,
  "statements": 70
}
